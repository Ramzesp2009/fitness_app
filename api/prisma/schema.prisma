generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username  String   @unique @db.VarChar(50)
  email     String   @unique @db.VarChar(100)
  password  String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  programs    Program[]
  exercises   Exercise[]
  workouts    Workout[]
  following   Follow[]   @relation("follower")
  followers   Follow[]   @relation("following")

  @@map("users")
}

model Program {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  cycleType   String   @default("weekly") @map("cycle_type") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks   ProgramWeek[]
  workouts Workout[]

  @@map("programs")
}

model ProgramWeek {
  id         String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  programId  String @map("program_id") @db.Uuid
  weekNumber Int    @map("week_number")
  intensity  String @db.VarChar(10)

  program  Program   @relation(fields: [programId], references: [id], onDelete: Cascade)
  workouts Workout[]

  @@unique([programId, weekNumber])
  @@map("program_weeks")
}

model Exercise {
  id          String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String  @db.VarChar(100)
  muscleGroup String? @map("muscle_group") @db.VarChar(100)
  isCustom    Boolean @default(false) @map("is_custom")
  userId      String? @map("user_id") @db.Uuid

  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  workoutSets WorkoutSet[]

  @@map("exercises")
}

model Workout {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  programId String?  @map("program_id") @db.Uuid
  weekId    String?  @map("week_id") @db.Uuid
  name      String?  @db.VarChar(100)
  date      DateTime @default(dbgenerated("CURRENT_DATE")) @db.Date
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program?     @relation(fields: [programId], references: [id], onDelete: SetNull)
  week    ProgramWeek? @relation(fields: [weekId], references: [id], onDelete: SetNull)
  sets    WorkoutSet[]

  @@index([userId, date(sort: Desc)], map: "idx_workouts_user_date")
  @@map("workouts")
}

model WorkoutSet {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  workoutId   String   @map("workout_id") @db.Uuid
  exerciseId  String   @map("exercises_id") @db.Uuid
  setNumber   Int      @map("set_number")
  reps        Int?
  weightKg    Decimal? @map("weight_kg") @db.Decimal(6, 2)
  rpe         Decimal? @db.Decimal(3, 1)
  oneRm       Decimal? @map("one_rm") @db.Decimal(6, 2)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id])

  @@index([workoutId], map: "idx_workout_sets_workout")
  @@map("workout_sets")
}

model Follow {
  followerId  String   @map("follower_id") @db.Uuid
  followingId String   @map("following_id") @db.Uuid
  status      String   @default("pending") @db.VarChar(25)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId, status], map: "idx_follws_following")
  @@map("follows")
}
