{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["node"]
  },
  "include": [
    "**/*.ts",
    "prisma.config.ts"
  ],
  "exclude": [
    "node_modules",
    "prisma/**/*.js"
  ]
}